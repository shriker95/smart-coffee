# ESPHome Secrets Template
# Copy this file to secrets.yaml and fill in your values.
# secrets.yaml must NOT be committed to version control.

wifi_ssid: "Your_WiFi_SSID"
wifi_password: "your_wifi_password"

# Fallback AP password (shown when WiFi connection fails)
ap_password: "your_ap_password"

# OTA update password
ota_password: "your_ota_password"

# Home Assistant API encryption key (generate with: openssl rand -base64 32)
api_key: "your_base64_api_encryption_key="
